# ============================================
# Proveedor de IA
# Opciones: gemini | ollama
# ============================================
AI_PROVIDER=gemini

# ============================================
# Gemini (activo cuando AI_PROVIDER=gemini)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=60000

# ============================================
# Base de datos MySQL
# ============================================
DB_HOST=mysql
DB_USER=app_user
DB_PASSWORD=change_me_secure_password
DB_NAME=entrevistas_virtuales
DB_ROOT_PASSWORD=change_me_root_password

# ============================================
# JWT
# ============================================
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# ============================================
# Google OAuth
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================
# Ollama
# ============================================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_ROUTER_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=120000
OLLAMA_GENERATE_TIMEOUT=120000
OLLAMA_FALLBACK_TIMEOUT=150000
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=180
OLLAMA_NUM_CTX=2048
OLLAMA_FALLBACK_NUM_CTX=1536
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_THREAD=6
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_FLASH_ATTENTION=1
OLLAMA_EMBEDDING_KEEP_ALIVE=60m
OLLAMA_RETRY_ATTEMPTS=1
OLLAMA_RETRY_BASE_DELAY_MS=1200
OLLAMA_CPU_LIMIT=8.0
OLLAMA_MEM_LIMIT=12g
OLLAMA_MEM_RESERVATION=6g

# ============================================
# ChromaDB (Embeddings)
# ============================================
CHROMA_URL=http://chromadb:8000
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_INDEX_BATCH_SIZE=12

# ============================================
# Calidad de respuestas IA (prompt)
# ============================================
# Presupuesto de prompt/contexto (el chat 1-a-1 usa selección determinística
# de secciones por intención, no búsqueda semántica — ver ContextSelectorService)
PROMPT_MAX_CHARS=7200
PROMPT_PROFILE_MAX_CHARS=2200
PROMPT_MEMORY_MAX_CHARS=600

# ============================================
# GitHub (import de datos públicos al perfil, opcional)
# GITHUB_TOKEN es un PAT sin scopes, solo para subir el rate limit de
# 60/hora sin auth a 5000/hora — no es necesario para que la feature funcione.
# ============================================
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=

# ============================================
# App
# ============================================
PORT=3000
NODE_ENV=production
