# ============================================
# Proveedor de IA
# Opciones: gemini | ollama
# ============================================
AI_PROVIDER=gemini

# ============================================
# Gemini (activo cuando AI_PROVIDER=gemini)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=60000

# ============================================
# Base de datos MySQL
# ============================================
DB_HOST=mysql
DB_USER=app_user
DB_PASSWORD=change_me_secure_password
DB_NAME=entrevistas_virtuales
DB_ROOT_PASSWORD=change_me_root_password

# ============================================
# JWT
# ============================================
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# ============================================
# Google OAuth
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================
# Ollama
# ============================================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_ROUTER_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=120000
OLLAMA_GENERATE_TIMEOUT=120000
OLLAMA_FALLBACK_TIMEOUT=150000
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=180
OLLAMA_NUM_CTX=2048
OLLAMA_FALLBACK_NUM_CTX=1536
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_THREAD=6
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_FLASH_ATTENTION=1
OLLAMA_EMBEDDING_KEEP_ALIVE=60m
OLLAMA_RETRY_ATTEMPTS=1
OLLAMA_RETRY_BASE_DELAY_MS=1200
OLLAMA_CPU_LIMIT=8.0
OLLAMA_MEM_LIMIT=12g
OLLAMA_MEM_RESERVATION=6g

# ============================================
# ChromaDB (Embeddings)
# ============================================
CHROMA_URL=http://chromadb:8000
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_INDEX_BATCH_SIZE=12

# ============================================
# Calidad de respuestas IA (retrieval + prompt)
# ============================================
# Top-k dinámico
SEMANTIC_TOPK_MIN=2
SEMANTIC_TOPK_DEFAULT=3
SEMANTIC_TOPK_MAX=5
DISABLE_RAG_BELOW_CONFIDENCE=0.3

# Umbral mínimo semántico base
SEMANTIC_MIN_SIMILARITY=0.68

# Umbral por tipo de consulta (JSON)
# fact: consultas puntuales (contacto, disponibilidad, etc.)
# detail: consultas de experiencia/proyectos/skills
# general: consultas amplias
SEMANTIC_MIN_SIMILARITY_BY_TYPE={"fact":0.74,"detail":0.69,"general":0.66}

# Dedupe semántico y recorte de chunks
SEMANTIC_NEAR_DUPLICATE_THRESHOLD=0.9
SEMANTIC_CHUNK_MAX_CHARS=420

# Híbrido BM25 + semántico
ENABLE_HYBRID_SEARCH=true
HYBRID_SEMANTIC_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4
HYBRID_MAX_RESULTS=5
HYBRID_DEDUPE_THRESHOLD=0.8

# Reranking sin embeddings adicionales
ENABLE_RERANKING=true

# Presupuesto de prompt/contexto
PROMPT_MAX_CHARS=7200
PROMPT_PROFILE_MAX_CHARS=2200
PROMPT_SEMANTIC_MAX_CHARS=1800
PROMPT_SEMANTIC_MAX_CHUNKS=5
PROMPT_SEMANTIC_CHUNK_MAX_CHARS=280
PROMPT_MEMORY_MAX_CHARS=600

# ============================================
# App
# ============================================
PORT=3000
NODE_ENV=production
