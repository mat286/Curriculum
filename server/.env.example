# ============================================
# Proveedor de IA
# Opciones: gemini | ollama
# ============================================
AI_PROVIDER=gemini

# ============================================
# Gemini (activo cuando AI_PROVIDER=gemini)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT=60000

# ============================================
# Base de datos MySQL
# ============================================
DB_HOST=mysql
DB_USER=app_user
DB_PASSWORD=change_me_secure_password
DB_NAME=entrevistas_virtuales
DB_ROOT_PASSWORD=change_me_root_password

# ============================================
# JWT
# ============================================
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# ============================================
# Google OAuth
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ============================================
# Ollama
# ============================================
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_ROUTER_MODEL=llama3.2:1b
OLLAMA_TIMEOUT=60000
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=180
OLLAMA_NUM_CTX=3072
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_THREAD=6
OLLAMA_CPU_LIMIT=6.0
OLLAMA_MEM_LIMIT=8g
OLLAMA_MEM_RESERVATION=4g

# ============================================
# ChromaDB (Embeddings)
# ============================================
CHROMA_URL=http://chromadb:8000
EMBEDDING_MODEL=nomic-embed-text

# ============================================
# App
# ============================================
PORT=3000
NODE_ENV=production
